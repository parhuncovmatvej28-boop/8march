body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background-color: #f0f0f0;
    font-family: Arial, Helvetica, sans-serif;
}

#app {
    text-align: center;
    max-width: 400px;
}

#steps li {
    list-style-type: none;
    margin: 10px 0;
    padding: 10px;
    background-color: #fff;
    border-radius: 5px;
    box-shadow: 0 2px 5px rgba(0,0,0,.1);
}

.active-step {
    background-color: lightgreen !important;
}